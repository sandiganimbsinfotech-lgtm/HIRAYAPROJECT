<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HirayaPursuit Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-50">

<div class="flex flex-col md:flex-row min-h-screen">
  
  <aside class="w-full md:w-64 bg-[#800000] text-white md:h-screen sticky top-0 flex flex-col justify-between p-6">
    <div>
      <div class="flex items-center gap-2 mb-10">
        <div class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center font-bold text-xs">
            <span class="text-white">✨</span>
        </div>
        <h1 class="text-xl font-bold tracking-tight">Hiraya Pursuit</h1>
      </div>

      <nav class="space-y-1 text-sm">
        <div class="flex items-center gap-3 p-3 bg-white/10 rounded-lg font-semibold cursor-pointer">
            <span>⊞</span> Dashboard
        </div>
        <div class="flex items-center gap-3 p-3 opacity-60 hover:bg-white/10 rounded-lg cursor-pointer transition">
            <span>💼</span> Jobs
        </div>
        <div class="flex items-center gap-3 p-3 opacity-60 hover:bg-white/10 rounded-lg cursor-pointer transition">
            <span>📝</span> My Applications
        </div>
        <div class="flex items-center gap-3 p-3 opacity-60 hover:bg-white/10 rounded-lg cursor-pointer transition">
            <span>💬</span> Messages
        </div>
        <div class="flex items-center gap-3 p-3 opacity-60 hover:bg-white/10 rounded-lg cursor-pointer transition">
            <span>👤</span> Profile
        </div>
        <div class="flex items-center gap-3 p-3 opacity-60 hover:bg-white/10 rounded-lg cursor-pointer transition">
            <span>⚙️</span> Settings
        </div>
      </nav>
    </div>

    <div class="mt-10 pt-6 border-t border-white/20 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <img src="https://ui-avatars.com/api/?name=John+Mark+Acebedo&background=FFC0CB&color=800000" class="w-10 h-10 rounded-full border-2 border-white/20" alt="Avatar">
        <div>
          <p class="text-xs font-bold">John Mark Acebedo</p>
          <p class="text-[10px] text-white/60">acebedojm.com</p>
        </div>
      </div>
      <button class="text-white/60 hover:text-white">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
      </button>
    </div>
  </aside>

  <main class="flex-1 p-4 md:p-10">
    
    <div class="max-w-6xl mx-auto mb-10 flex gap-4">
      <input type="text" placeholder="Search for jobs..." class="flex-1 px-4 py-3 rounded-xl border border-gray-200 outline-none shadow-sm">
      <button class="px-6 py-3 bg-white border border-gray-200 rounded-xl font-medium">Filters</button>
      <button class="px-10 py-3 bg-[#800000] text-white rounded-xl font-bold">Search</button>
    </div>

    <div class="max-w-6xl mx-auto flex justify-between items-end mb-8">
      <div>

    <div class="mb-10">
      <p class="text-gray-400 text-sm font-medium">Tuesday, March 3rd</p>
      <h2 class="text-4xl font-extrabold text-slate-800 mt-1">Welcome to Hiraya <br class="md:hidden">John,</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-6 mb-12">
      <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex items-center justify-between">
        <div class="flex items-center gap-4">
            <div class=" rounded-lg bg-red-50 flex items-center justify-center text-[#800000]">💼</div>
            <span class="text-sm font-semibold text-gray-500">Application Sent</span>
        </div>
        <span class="text-2xl font-bold text-gray-800">42</span>
      </div>
      <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex items-center justify-between">
        <div class="flex items-center gap-4">
            <div class=" rounded-lg bg-red-50 flex items-center justify-center text-[#800000]">👤</div>
            <span class="text-sm font-semibold text-gray-500">Profile Viewed</span>
        </div>
        <span class="text-2xl font-bold text-gray-800">40</span>
      </div>
      
    </div>

    <div class="flex justify-between items-center mb-6">
      <h3 class="text-2xl font-bold text-slate-800">Recommended for you</h3>
      <button class="text-sm font-bold text-gray-400 hover:text-[#800000] transition">View All</button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      
      <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm hover:shadow-md transition group">
        <div class="flex justify-between items-start mb-6">
          <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-xl group-hover:scale-110 transition">🎨</div>
          <button class="text-gray-300 hover:text-[#800000]">🔖</button>
        </div>
        <h4 class="text-xl font-bold mb-2">Senior Product Designer</h4>
        <p class="text-gray-500 text-sm leading-relaxed mb-8">Design and maintain scalable design systems for global products. Collaborate with cross-functional teams to deliver exceptional UX.</p>
        <div class="flex justify-between items-center pt-5 border-t border-gray-50">
          <span class="font-extrabold text-[#800000] text-lg">$120k - $150k</span>
          <button class="px-6 py-2.5 bg-[#800000] text-white rounded-xl font-bold hover:bg-[#600000] transition">Open</button>
        </div>
      </div>

      <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm hover:shadow-md transition group">
        <div class="flex justify-between items-start mb-6">
          <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-xl group-hover:scale-110 transition">
            <span class="text-red-800 font-mono font-bold">&lt;/&gt;</span>
          </div>
          <button class="text-gray-300 hover:text-[#800000]">🔖</button>
        </div>
        <h4 class="text-xl font-bold mb-2">Frontend Engineer</h4>
        <p class="text-gray-500 text-sm leading-relaxed mb-8">Build responsive web applications using React and Tailwind. Focus on performance, accessibility, and clean architecture.</p>
        <div class="flex justify-between items-center pt-5 border-t border-gray-50">
          <span class="font-extrabold text-[#800000] text-lg">$110k - $140k</span>
          <button class="px-6 py-2.5 bg-[#800000] text-white rounded-xl font-bold hover:bg-[#600000] transition">Open</button>
        </div>
      </div>

      <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm hover:shadow-md transition group">
        <div class="flex justify-between items-start mb-6">
          <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-xl group-hover:scale-110 transition">📢</div>
          <button class="text-gray-300 hover:text-[#800000]">🔖</button>
        </div>
        <h4 class="text-xl font-bold mb-2">Marketing Manager</h4>
        <p class="text-gray-500 text-sm leading-relaxed mb-8">Lead multi-channel marketing campaigns and growth strategies. Analyze metrics to optimize customer acquisition costs.</p>
        <div class="flex justify-between items-center pt-5 border-t border-gray-50">
          <span class="font-extrabold text-[#800000] text-lg">$90k - $120k</span>
          <button class="px-6 py-2.5 bg-[#800000] text-white rounded-xl font-bold hover:bg-[#600000] transition">Open</button>
        </div>
      </div>

    </div>

  </main>
</div>

</body>
</html>
