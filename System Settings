<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>System Settings</title>

<script src="https://cdn.tailwindcss.com"></script>


 <script>
function toggleSidebar() {
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('overlay');

    sidebar.classList.toggle('-translate-x-full');
    overlay.classList.toggle('hidden');
}

</script>
</head>

<body class="bg-gray-100">

<div class="flex h-screen overflow-hidden">

    <!-- SIDEBAR -->
<aside id="sidebar"
class="fixed z-40 inset-y-0 left-0 w-64 bg-white border-r transform -translate-x-full transition-transform duration-300
md:relative md:translate-x-0 md:flex md:flex-col">

    <!-- LOGO -->
    <div class="p-4 flex items-center gap-3 border-b">
        <img src="Hiraya2.png" class="w-10 h-10 rounded-full">
        <div>
            <h1 class="text-sm font-bold text-red-900">HIRAYA PURSUITS</h1>
            <p class="text-xs text-gray-400">ADMIN CONSOLE</p>
        </div>
    </div>

    <!-- NAV -->
    <nav class="flex-1 p-4 space-y-2 text-sm">
        <a class="block px-3 py-2 rounded hover:bg-gray-100">Dashboard</a>
        <a class="block px-3 py-2 rounded hover:bg-gray-100">Applicants</a>
        <a class="block px-3 py-2 rounded hover:bg-gray-100">Employers</a>
        <a class="block px-3 py-2 rounded hover:bg-gray-100">Jobs</a>
        <a class="block px-3 py-2 rounded hover:bg-gray-100">Roles</a>

        <a class="block px-3 py-2 rounded bg-red-50 text-red-700 font-semibold">
            Settings
        </a>

        <a class="block px-3 py-2 rounded hover:bg-gray-100">Logout</a>
    </nav>

    <!-- USER -->
    <div class="p-4 border-t flex items-center gap-3 bg-red-50 m-3 rounded-lg">
        <div class="w-8 h-8 bg-red-200 rounded-full"></div>
        <div>
            <p class="text-sm font-bold text-red-900">Alex Hiraya</p>
            <p class="text-xs text-gray-500">Super Admin</p>
        </div>
    </div>

</aside>

        <div id="overlay"
            class="fixed inset-0 bg-black bg-opacity-30 hidden z-30 md:hidden"
            onclick="toggleSidebar()">
        </div>

    <!-- MAIN -->
    <div class="flex-1 flex flex-col">

        <!-- TOPBAR -->
        <header class="bg-white px-4 py-3 flex justify-between items-center border-b">

    <!-- LEFT -->
    <div class="flex items-center gap-3">

        <!-- MENU BUTTON -->
        <button onclick="toggleSidebar()" class="md:hidden">
            <svg xmlns="http://www.w3.org/2000/svg" 
                class="w-6 h-6 text-gray-700" 
                fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>

        <input type="text" placeholder="Search settings..."
            class="w-40 sm:w-64 md:w-80 px-3 py-2 border rounded-lg text-sm">
    </div>

    <!-- RIGHT -->
    <div class="flex items-center gap-3">
        <span class="text-sm font-semibold text-gray-700 hidden sm:block">
            Super Admin
        </span>
        <img src="https://via.placeholder.com/35" class="w-8 h-8 rounded-full">
    </div>

</header>

        <!-- CONTENT -->
        <main class="p-4 overflow-y-auto">

            <!-- TITLE -->
            <h1 class="text-xl font-bold text-gray-800">System Settings</h1>
            <p class="text-sm text-gray-500 mb-6">
                Global configuration for your platform's branding, security, and operation.
            </p>

            <!-- SYSTEM IDENTITY -->
            <div class="bg-white p-5 rounded-xl border mb-4">
                <h2 class="font-semibold text-gray-800 mb-4">System Identity</h2>

                <div class="grid md:grid-cols-2 gap-4">
                    <input type="text" value="HIRAYA PURSUITS"
                        class="border p-2 rounded-lg text-sm">

                    <input type="text" placeholder="Website Title"
                        class="border p-2 rounded-lg text-sm">

                    <input type="text" placeholder="Tagline"
                        class="border p-2 rounded-lg text-sm md:col-span-2">
                </div>
            </div>

            <!-- BRANDING -->
            <div class="bg-white p-5 rounded-xl border mb-4">
                <h2 class="font-semibold text-gray-800 mb-4">Branding Assets</h2>

                <div class="flex flex-col md:flex-row gap-6">

                    <!-- LOGO -->
                    <div>
                        <img src="Hiraya2.png" alt="Hiraya Logo" class="rounded-full mb-2">
                        <button class="text-sm bg-gray-100 px-3 py-1 rounded">Upload New</button>
                    </div>

                    <!-- COLORS -->
                    <div class="flex gap-6">
                        <div>
                            <p class="text-sm">Primary Color</p>
                            <div class="w-10 h-6 bg-red-800 rounded"></div>
                        </div>

                        <div>
                            <p class="text-sm">Secondary Color</p>
                            <div class="w-10 h-6 bg-gray-300 rounded"></div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- WEBSITE CONFIG -->
            <div class="bg-white p-5 rounded-xl border mb-4">
                <h2 class="font-semibold text-gray-800 mb-4">Website Configuration</h2>

                <div class="space-y-4">

                    <!-- TOGGLE -->
                    <div class="flex justify-between items-center">
                        <div>
                            <p class="font-medium text-sm">Maintenance Mode</p>
                            <p class="text-xs text-gray-400">Temporarily disable public access</p>
                        </div>
                        <div class="w-10 h-5 bg-gray-300 rounded-full"></div>
                    </div>

                    <div class="flex justify-between items-center">
                        <p class="text-sm">Enable Registration</p>
                        <div class="w-10 h-5 bg-red-700 rounded-full"></div>
                    </div>

                    <div class="flex justify-between items-center">
                        <p class="text-sm">Email Notifications</p>
                        <div class="w-10 h-5 bg-red-700 rounded-full"></div>
                    </div>

                </div>
            </div>

            <!-- SECURITY (SCROLL TARGET) -->
            <div class="bg-white p-5 rounded-xl border mb-6">
                <h2 class="font-semibold text-gray-800 mb-4">Security</h2>

                <div class="grid md:grid-cols-2 gap-4 mb-4">
                    <select class="border p-2 rounded-lg text-sm">
                        <option>Moderate (Numbers, Min 8 chars)</option>
                    </select>

                    <input type="text" value="30"
                        class="border p-2 rounded-lg text-sm">
                </div>

                <div class="flex justify-between items-center">
                    <div>
                        <p class="font-medium text-sm">Two-Factor Authentication</p>
                        <p class="text-xs text-gray-400">
                            Force users to verify identity with a secondary device
                        </p>
                    </div>
                    <div class="w-10 h-5 bg-gray-300 rounded-full"></div>
                </div>
            </div>

            <!-- ACTIONS -->
            <div class="flex justify-end gap-4 items-center">
                <button class="text-gray-500 text-sm">Discard Changes</button>

                <button class="bg-red-800 text-white px-6 py-2 rounded-lg shadow-lg text-sm">
                    Save Changes
                </button>
            </div>

        </main>

    </div>

</div>

</body>
</html>
